# Zerodha Kite API Credentials Configuration
# 
# INSTRUCTIONS:
# 1. Copy this file to .env (rename from .env.example to .env)
# 2. Replace the placeholder values with your actual credentials
# 3. Keep this file PRIVATE - never commit to GitHub
# 4. Add .env to .gitignore to prevent accidental sharing
#
# ⚠️ SECURITY WARNING: NEVER share your access token or API key!
# ⚠️ If exposed, regenerate immediately from developers.kite.trade

# Your Kite API Key (from developers.kite.trade)
KITE_API_KEY=zudyrwgcegy6o0nw

# Your Kite Access Token (generated after login)
KITE_ACCESS_TOKEN=V5LrziJLsUJNkJC0UZKdNW0eboiRWLLf

# Your Kite App Secret (from app settings)
KITE_APP_SECRET=p9ru97bcm6jc9r3ycz4ok4unizyysv1z

# Your Zerodha User ID (optional, for reference)
ZERODHA_USER_ID=your_zerodha_user_id

# Logging Configuration
